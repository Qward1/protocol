# --- Секреты и конфиги (не коммитим) ---
backend/config.yaml
microservice/config.json
*.env
.env

# --- Хранилища / данные ---
storage/
**/storage/
*.db
*.sqlite
*.sqlite3

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# --- Node / Frontend ---
node_modules/
dist/
.vite/
*.local
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# --- Логи / временные ---
*.log
*.out
*.err
tmp/
.cache/

# --- IDE / ОС ---
.idea/
.vscode/
.claude/
.DS_Store
Thumbs.db

# --- Инструкции ИИ-ассистентов (только локально) ---
CLAUDE.md
AGENTS.md
.cursorrules

# --- Dify workflow (хранится локально, не в репозитории) ---
dify/*.yml
dify/*.yaml

# --- Скриншоты / артефакты QA и MCP (только локально) ---
/*.png
/*.jpg
/*.jpeg
/*.gif
.playwright-mcp/

# --- Markdown: в репозиторий попадает только корневой README.md ---
*.md
!/README.md
